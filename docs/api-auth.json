{
  "_base_url": "http://localhost:8000",
  "_description": "TestHub 用户认证 API",

  "register": {
    "method": "POST",
    "url": "/api/auth/register/",
    "auth": "无需认证",
    "content-type": "application/json",
    "request": {
      "username": "必填",
      "email": "必填",
      "password": "必填, 最小6位",
      "password_confirm": "必填, 需与 password 一致",
      "first_name": "选填",
      "last_name": "选填",
      "phone": "选填",
      "department": "选填",
      "position": "选填"
    },
    "request_example": {
      "username": "newuser",
      "email": "newuser@example.com",
      "password": "pass123456",
      "password_confirm": "pass123456"
    },
    "response_success_201": {
      "user": {
        "id": 3,
        "username": "newuser",
        "email": "newuser@example.com",
        "first_name": "",
        "last_name": "",
        "avatar": null,
        "phone": null,
        "department": null,
        "position": null,
        "is_active": true,
        "date_joined": "2026-06-30T10:00:00+08:00",
        "created_at": "2026-06-30T10:00:00+08:00",
        "updated_at": "2026-06-30T10:00:00+08:00"
      },
      "token": "3f8a9b2c1d..."
    }
  },

  "login": {
    "method": "POST",
    "url": "/api/auth/login/",
    "auth": "无需认证",
    "content-type": "application/json",
    "request": {
      "username": "必填",
      "password": "必填"
    },
    "request_example": {
      "username": "admin",
      "password": "admin123"
    },
    "response_success_200": {
      "user": {
        "id": 1,
        "username": "admin",
        "email": "admin@testhub.com",
        "first_name": "",
        "last_name": "",
        "avatar": null,
        "phone": null,
        "department": null,
        "position": null,
        "is_active": true,
        "date_joined": "2026-01-01T00:00:00+08:00",
        "created_at": "2026-01-01T00:00:00+08:00",
        "updated_at": "2026-01-01T00:00:00+08:00"
      },
      "access": "eyJhbGciOiJIUzI1NiIs...",
      "refresh": "eyJhbGciOiJIUzI1NiIs...",
      "message": "登录成功"
    },
    "response_error_400": {
      "non_field_errors": ["用户名或密码错误"]
    }
  },

  "me": {
    "method": "GET",
    "url": "/api/auth/me/",
    "auth": "需要 Bearer Token",
    "headers": {
      "Authorization": "Bearer <access_token>"
    },
    "response_success_200": {
      "id": 1,
      "username": "admin",
      "email": "admin@testhub.com",
      "first_name": "",
      "last_name": "",
      "avatar": null,
      "phone": null,
      "department": null,
      "position": null,
      "is_active": true,
      "date_joined": "2026-01-01T00:00:00+08:00",
      "created_at": "2026-01-01T00:00:00+08:00",
      "updated_at": "2026-01-01T00:00:00+08:00"
    }
  },

  "profile": {
    "method": "GET",
    "url": "/api/auth/profile/",
    "auth": "需要 Bearer Token",
    "headers": {
      "Authorization": "Bearer <access_token>"
    },
    "response_success_200": {
      "id": 1,
      "username": "admin",
      "email": "admin@testhub.com",
      "first_name": "",
      "last_name": "",
      "avatar": null,
      "phone": null,
      "department": null,
      "position": null,
      "is_active": true,
      "date_joined": "2026-01-01T00:00:00+08:00",
      "created_at": "2026-01-01T00:00:00+08:00",
      "updated_at": "2026-01-01T00:00:00+08:00"
    }
  },

  "users": {
    "method": "GET",
    "url": "/api/auth/users/",
    "auth": "需要 Bearer Token",
    "headers": {
      "Authorization": "Bearer <access_token>"
    },
    "response_success_200": [
      {
        "id": 1,
        "username": "admin",
        "email": "admin@testhub.com",
        "first_name": "",
        "last_name": "",
        "avatar": null,
        "phone": null,
        "department": null,
        "position": null,
        "is_active": true,
        "date_joined": "2026-01-01T00:00:00+08:00",
        "created_at": "2026-01-01T00:00:00+08:00",
        "updated_at": "2026-01-01T00:00:00+08:00"
      }
    ]
  },

  "token_refresh": {
    "method": "POST",
    "url": "/api/auth/token/refresh/",
    "auth": "无需认证（需提供 refresh token）",
    "content-type": "application/json",
    "request": {
      "refresh": "必填, 登录时返回的 refresh token"
    },
    "request_example": {
      "refresh": "eyJhbGciOiJIUzI1NiIs..."
    },
    "response_success_200": {
      "access": "eyJhbGciOiJIUzI1NiIs...",
      "access_token_expiration": "2026-06-30T11:00:00+08:00"
    }
  }
}
